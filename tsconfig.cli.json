{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false,
    "types": ["node"]
  },
  "include": [
    "src/cli.ts",
    "src/mockData.ts",
    "src/aggregator.ts",
    "src/rules.ts",
    "src/recommendations.ts",
    "src/types.ts",
    "src/router/**/*.ts"
  ],
  "exclude": [
    "src/App.tsx",
    "src/main.tsx",
    "src/App.css",
    "src/index.css"
  ]
}
