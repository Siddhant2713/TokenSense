# ─── BYOK Server-Key Tier (Optional) ──────────────────────────────────────────
# Leave blank for pure BYOK deployments.
# Set this key if you want the server to handle AI analysis server-side,
# so users do not need to supply their own API keys.
OPENAI_API_KEY=

# ─── Phase 2+ — Authentication ─────────────────────────────────────────────────
# JWT_SECRET=       # 64-char random hex  (generate: openssl rand -hex 32)
# ENCRYPTION_KEY=   # 32-char random hex  (generate: openssl rand -hex 16)

# ─── Phase 1+ — Queue ──────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Phase 2+ — Primary Database ───────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tokensense

# ─── Phase 4+ — Analytics Database ─────────────────────────────────────────────
# CLICKHOUSE_URL=http://localhost:8123

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# ENABLE_PROXY_GATEWAY=true
# ENABLE_WEBHOOKS=true
# ENABLE_CLICKHOUSE=true
